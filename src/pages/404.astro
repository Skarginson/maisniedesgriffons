---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" description="Cette page n'existe pas ou a été déplacée.">
  <div class="not-found">
    <div class="container">
      <p class="not-found-code">404</p>
      <div class="accent-line"></div>
      <h1 class="not-found-title">Page introuvable</h1>
      <p class="not-found-text">
        La page que vous cherchez n'existe pas ou a été déplacée.<br />
        Peut-être s'est-elle égarée quelque part entre le XIIIème siècle et aujourd'hui.
      </p>
      <div class="not-found-links">
        <a href="/" class="btn">Retour à l'accueil</a>
        <a href="/les-animations/" class="btn">Nos animations</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.not-found {
  min-height: calc(100vh - 72px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rem var(--px);
  text-align: center;
}

.not-found-code {
  font-family: var(--font-serif);
  font-size: clamp(6rem, 20vw, 12rem);
  color: var(--border);
  line-height: 1;
  margin-bottom: 1.5rem;
  user-select: none;
}

.accent-line {
  margin-inline: auto;
  margin-bottom: 2rem;
}

.not-found-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: var(--text);
  margin-bottom: 1.5rem;
}

.not-found-text {
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.85;
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: 3rem;
}

.not-found-links {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
</style>
