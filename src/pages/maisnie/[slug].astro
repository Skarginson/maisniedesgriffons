---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const membres = await getCollection('membres');
  return membres.map(m => ({
    params: { slug: m.slug },
    props: { membre: m },
  }));
}

const { membre } = Astro.props;
const { title, role, photo, photoAlt } = membre.data;
const { Content } = await render(membre);
---

<BaseLayout title={title} description={`${title}, ${role} - La Maisnie des Griffons`}>
  <div class="page-header">
    <div class="container">
      <p class="breadcrumb"><a href="/maisnie/">La Maisnie</a> / {title}</p>
      <h1 class="page-title">{title}</h1>
      <p class="page-subtitle">{role}</p>
    </div>
  </div>

  <section class="membre-section">
    <div class="container membre-inner">
      <div class="membre-text reveal">
        <Content />
      </div>
      <div class="membre-photo reveal">
        <img src={photo} alt={photoAlt} loading="eager" />
      </div>
    </div>
  </section>

  <div class="page-nav container">
    <a href="/maisnie/" class="btn">← Retour à la Maisnie</a>
  </div>
</BaseLayout>

<style>
.membre-section { padding: 3rem 0 2rem; }
.membre-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}
@media (min-width: 768px) {
  .membre-inner { grid-template-columns: 1fr 340px; }
}
.membre-text :global(p) {
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.85;
  margin-bottom: 1.25rem;
}
.membre-photo img {
  width: 100%;
  object-fit: cover;
  object-position: top;
}
</style>
