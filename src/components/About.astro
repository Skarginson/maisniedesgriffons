---
import site from '../data/site.json';
---

<section class="about" id="about">
  <div class="container about-inner">
    <div class="about-text reveal">
      <h2 class="section-title">{site.about.title}</h2>
      <div class="accent-line"></div>
      {site.about.paragraphs
        ? site.about.paragraphs.map((p: string, i: number) => (
            <p class:list={[{ 'definition': i === 1 }]}>{p}</p>
          ))
        : <p>{site.about.text}</p>
      }
      <div class="about-links">
        <a href="/maisnie/" class="btn">La Maisnie</a>
        <a href="/les-animations/" class="btn">Les Animations</a>
      </div>
    </div>
    {site.about.image && (
      <div class="about-image reveal">
        <img src={site.about.image} alt={site.about.imageAlt} loading="lazy" onerror="this.onerror=null;this.src='/placeholder.svg'" />
      </div>
    )}
  </div>
</section>

<style>
.about { padding: clamp(5rem, 12vw, 9rem) 0; }
.about-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
  align-items: center;
}
@media (min-width: 768px) {
  .about-inner { grid-template-columns: 1fr 1fr; }
}
.about-text p {
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.85;
  margin-bottom: 1.25rem;
}
.about-text p:last-of-type {
  margin-bottom: 2.5rem;
}
.about-text p.definition {
  font-style: italic;
  border-left: 2px solid var(--accent);
  padding-left: 1rem;
  color: var(--text-muted);
}
.about-links { display: flex; gap: 1rem; flex-wrap: wrap; }
.about-image img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
}
</style>
