---
interface Props {
  title: string;
  slug: string;
  role: string;
  photo: string;
  photoAlt: string;
}

const { title, slug, role, photo, photoAlt } = Astro.props;
---

<article class="member-card reveal">
  <a href={`/maisnie/${slug}/`} class="member-link">
    <div class="member-media">
      <img src={photo} alt={photoAlt} loading="lazy" class="member-img" />
    </div>
    <div class="member-info">
      <h3 class="member-name">{title}</h3>
      <p class="member-role">{role}</p>
    </div>
  </a>
</article>

<style>
.member-link { display: block; }
.member-media {
  overflow: hidden;
  aspect-ratio: 3/4;
  background: var(--bg-card);
  margin-bottom: 1rem;
}
.member-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  transition: transform 0.6s ease;
}
.member-link:hover .member-img { transform: scale(1.04); }
.member-name {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  color: var(--text);
  margin-bottom: 0.3rem;
}
.member-role {
  font-size: 0.8rem;
  color: var(--accent);
  letter-spacing: 0.06em;
}
</style>
