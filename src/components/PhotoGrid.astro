---
interface Props {
  photos: { image: string; alt: string }[];
  galleryTitle: string;
}

const { photos, galleryTitle } = Astro.props;
---

<div class="photo-grid">
  {photos.map((photo, i) => (
    <a
      href={photo.image}
      class="photo-item glightbox"
      data-gallery={galleryTitle}
      aria-label={photo.alt}
    >
      <img
        src={photo.image}
        alt={photo.alt}
        loading={i < 4 ? 'eager' : 'lazy'}
        class="photo-img"
        onerror="this.onerror=null;this.src='/placeholder.svg'"
      />
    </a>
  ))}
</div>

<style>
.photo-grid {
  columns: 1;
  gap: 0.75rem;
}
@media (min-width: 480px) { .photo-grid { columns: 2; } }
@media (min-width: 900px) { .photo-grid { columns: 3; } }

.photo-item {
  display: block;
  break-inside: avoid;
  margin-bottom: 0.75rem;
  overflow: hidden;
  cursor: zoom-in;
  pointer-events: auto;
}
.photo-img {
  width: 100%;
  display: block;
  transition: transform 0.5s ease, filter 0.5s ease;
  filter: grayscale(10%);
  pointer-events: none;
}
.photo-item:hover .photo-img {
  transform: scale(1.03);
  filter: grayscale(0%);
}
</style>
